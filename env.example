# Copy this to .env.local for local dev
# Add these same keys in Vercel → Project Settings → Environment Variables

# Your Supabase project URL
# Found at: supabase.com → your project → Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co

# Your Supabase anon/public key (safe to expose — Supabase RLS controls access)
# Found at: supabase.com → your project → Settings → API → anon public
SUPABASE_ANON=eyYOUR-ANON-KEY-HERE
