{
  "rewrites": [
    {
      "source": "/api/scholar",
      "destination": "/api/scholar"
    },
    {
      "source": "/api/interpret-chart",
      "destination": "/api/interpret-chart"
    },
    {
      "source": "/api/hero-summary",
      "destination": "/api/hero-summary"
    },
    {
      "source": "/api/live-quote",
      "destination": "/api/live-quote"
    },
    {
      "source": "/api/live-quotes-batch",
      "destination": "/api/live-quotes-batch"
    },
    {
      "source": "/api/price-history",
      "destination": "/api/price-history"
    },
    {
      "source": "/api/ticker-snapshot",
      "destination": "/api/ticker-snapshot"
    },
    {
      "source": "/api/ticker-trades",
      "destination": "/api/ticker-trades"
    },
    {
      "source": "/api/ticker-fundamentals",
      "destination": "/api/ticker-fundamentals"
    },
    {
      "source": "/login",
      "destination": "/api/login"
    },
    {
      "source": "/pricing",
      "destination": "/api/pricing"
    },
    {
      "source": "/ticker/:ticker",
      "destination": "/api/ticker"
    },
    {
      "source": "/dashboard",
      "destination": "/api/dashboard"
    },
    {
      "source": "/search",
      "destination": "/api/search"
    },
    {
      "source": "/heatmap",
      "destination": "/api/heatmap"
    },
    {
      "source": "/daily",
      "destination": "/api/daily"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/blog-post"
    },
    {
      "source": "/blog",
      "destination": "/api/blog"
    },
    {
      "source": "/author/:slug",
      "destination": "/api/author?slug=:slug"
    },
    {
      "source": "/og-image/:slug",
      "destination": "/api/og-image?slug=:slug"
    },
    {
      "source": "/api/tickers/:ticker/meme-card",
      "destination": "/api/ticker-meme-card?ticker=:ticker"
    },
    {
      "source": "/terms",
      "destination": "/api/terms"
    },
    {
      "source": "/privacy",
      "destination": "/api/privacy"
    },
    {
      "source": "/methodology",
      "destination": "/api/methodology"
    },
    {
      "source": "/about",
      "destination": "/api/about"
    },
    {
      "source": "/features",
      "destination": "/api/features"
    },
    {
      "source": "/casestudies",
      "destination": "/api/casestudies"
    },
    {
      "source": "/signalstudies",
      "destination": "/api/signalstudies"
    },
    {
      "source": "/signal-charts",
      "destination": "/api/signal-charts"
    },
    {
      "source": "/casestudy/:slug",
      "destination": "/api/casestudy?slug=:slug"
    },
    {
      "source": "/faq",
      "destination": "/api/faq"
    },
    {
      "source": "/why-is-:ticker-stock-down",
      "destination": "/api/seo-why-down"
    },
    {
      "source": "/is-:ticker-overvalued",
      "destination": "/api/seo-overvalued"
    },
    {
      "source": "/should-i-buy-:ticker",
      "destination": "/api/seo-should-buy"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/news-sitemap.xml",
      "destination": "/api/news-sitemap"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/feed",
      "destination": "/api/feed"
    },
    {
      "source": "/atom.xml",
      "destination": "/api/feed?format=atom"
    },
    {
      "source": "/llms.txt",
      "destination": "/api/llms-txt"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/home-v2",
      "destination": "/api/home-v2"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "_home_v2.html"
    },
    "api/dashboard.js": {
      "includeFiles": "{_template.html,_signal_lab_tab.html,_ticker_tab.html}"
    },
    "api/dashboard-dev.js": {
      "includeFiles": "_template_dev.html"
    },
    "api/dashboard-v2.js": {
      "includeFiles": "_dashboard_v2.html"
    },
    "api/search.js": {
      "includeFiles": "_search.html"
    },
    "api/dots-predict.js": {
      "includeFiles": "node_modules/@xenova/transformers/dist/**",
      "maxDuration": 60
    },
    "api/ticker.js": {
      "includeFiles": "{_ticker.html,lib/**}"
    },
    "api/ticker-dev.js": {
      "includeFiles": "_ticker_dev.html"
    },
    "api/heatmap.js": {
      "includeFiles": "_heatmap.html"
    },
    "api/daily.js": {
      "includeFiles": "_daily.html"
    },
    "api/blog.js": {
      "includeFiles": "_blog.html"
    },
    "api/blog-post.js": {
      "includeFiles": "_blog_post.html"
    },
    "api/author.js": {
      "includeFiles": "_author.html"
    },
"api/methodology.js": {
      "includeFiles": "_methodology.html"
    },
    "api/about.js": {
      "includeFiles": "_about.html"
    },
    "api/features.js": {
      "includeFiles": "_features.html"
    },
    "api/terms.js": {
      "includeFiles": "_terms.html"
    },
    "api/privacy.js": {
      "includeFiles": "_privacy.html"
    },
    "api/casestudies.js": {
      "includeFiles": "_casestudies.html"
    },
    "api/signalstudies.js": {
      "includeFiles": "_signalstudies.html"
    },
    "api/faq.js": {
      "includeFiles": "_faq.html"
    },
    "api/casestudy.js": {
      "includeFiles": "casestudy/*.html"
    },
    "api/login.js": {
      "includeFiles": "_login.html"
    },
    "api/pricing.js": {
      "includeFiles": "pricing.html"
    },
"api/scorer-dev.js": {
      "includeFiles": "_scorer_dev.html"
    },
    "api/home-dev.js": {
      "includeFiles": "_home_dev.html"
    },
    "api/home-v2.js": {
      "includeFiles": "_home_v2.html"
    },
    "api/seo-why-down.js": {
      "includeFiles": "{_seo_ticker.html,lib/**}"
    },
    "api/seo-overvalued.js": {
      "includeFiles": "{_seo_ticker.html,lib/**}"
    },
    "api/seo-should-buy.js": {
      "includeFiles": "{_seo_ticker.html,lib/**}"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/dashboard",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=120, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
