{
  "rewrites": [
    { "source": "/ticker/:ticker", "destination": "/api/ticker" },
    { "source": "/(.*)",           "destination": "/api/index"  }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "../_template.html"
    },
    "api/ticker.js": {
      "includeFiles": "../_ticker.html"
    }
  }
}
